# Copie ce fichier vers .env.local pour le développement local.
# VITE_SUPABASE_URL doit être une URL HTTP(S) valide. La clé anonyme est
# publique par conception ; ne place jamais la clé service_role dans Vite.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
